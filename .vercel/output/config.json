{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/about/?(?:/__data.json)?$",
			"dest": "/about"
		},
		{
			"src": "^/api/calendar/?(?:/__data.json)?$",
			"dest": "/api/calendar"
		},
		{
			"src": "^/donate/?(?:/__data.json)?$",
			"dest": "/donate"
		},
		{
			"src": "^/gallery/?(?:/__data.json)?$",
			"dest": "/gallery"
		},
		{
			"src": "^/lessons/?(?:/__data.json)?$",
			"dest": "/lessons"
		},
		{
			"src": "^/privacy/?(?:/__data.json)?$",
			"dest": "/privacy"
		},
		{
			"src": "^/schedule/?(?:/__data.json)?$",
			"dest": "/schedule"
		},
		{
			"src": "^/support/?(?:/__data.json)?$",
			"dest": "/support"
		},
		{
			"src": "^/tournaments/?(?:/__data.json)?$",
			"dest": "/tournaments"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}